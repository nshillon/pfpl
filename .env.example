# pFPL Environment Variables
# ============================================================
# Copy these into Vercel: Settings → Environment Variables
# Also create .env.local for local dev (never commit this file)
# ============================================================

# ── Clerk ────────────────────────────────────────────────────
# Get from: clerk.com/dashboard → API Keys
VITE_CLERK_PUBLISHABLE_KEY=pk_live_...
CLERK_SECRET_KEY=sk_live_...            # SERVER ONLY — never prefix with VITE_

# ── Supabase ─────────────────────────────────────────────────
# Get from: supabase.com/dashboard → Project Settings → API
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJ...           # safe for frontend (RLS enforced)
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co   # SERVER ONLY (duplicate without VITE_)
SUPABASE_SERVICE_ROLE_KEY=eyJ...        # SERVER ONLY — never prefix with VITE_

# ── Stripe ───────────────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY=sk_live_...           # SERVER ONLY
STRIPE_PRO_PRICE_ID=price_...           # Your Pro subscription Price ID
STRIPE_WEBHOOK_SECRET=whsec_...         # Stripe Dashboard → Webhooks → signing secret
# Webhook URL to register in Stripe: https://predictivefpl.com/api/stripe-webhook

# ── App ──────────────────────────────────────────────────────
APP_URL=https://predictivefpl.com

# ── Anthropic (if calling from server) ───────────────────────
ANTHROPIC_API_KEY=sk-ant-...            # SERVER ONLY

# ============================================================
# Vercel env var scopes:
#   Production + Preview + Development  →  all VITE_ prefixed vars
#   Production only                     →  STRIPE_SECRET_KEY, CLERK_SECRET_KEY, SERVICE_ROLE_KEY
# ============================================================
